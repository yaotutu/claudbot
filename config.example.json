    "feishu": {
      "enabled": false,
      "appId": "",
      "appSecret": "",
      "verificationToken": "",
      "encryptKey": "",
      "webhookPath": "/channels/feishu/events",
      "allowedChatIds": []
    },
    "qq": {
      "enabled": false,
      "appId": "",
      "clientSecret": "",
      "sessionDir": "",
      "typingKeepAlive": true,
      "parseFaceEmoji": true,
      "allowedConversationIds": [],
      "allowedUserIds": [],
      "allowedGroupOpenids": []
    }
  },
  "tools": {
    "permissions": {
      "default": "allow",
      "overrides": {}
    }
  },
  "mcp": {
    "strict": true,
    "servers": {}
