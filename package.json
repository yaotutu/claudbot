{
  "name": "claudebot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "claudebot": "./src/server.ts"
  },
  "scripts": {
    "dev": "concurrently -k -n gateway,webui -c blue,cyan \"bun run --watch src/server.ts\" \"cd webui && bun run dev\"",
    "dev:server": "bun run --watch src/server.ts",
    "dev:webui": "cd webui && bun run dev",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.169",
    "cron-parser": "^5.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "typescript": "^5.9.3"
  }
}
